#ifndef Cosmos_NETROOTTRADE_H
#define Cosmos_NETROOTTRADE_H

#include <RootNetClientApi.h>
#include "../Types/OrderField.h"
#include "../Types/QuerySymbol.h"
#include "../Driver/RealtimeDriver.h"
#include "OrderCallBackHandler.h"
#include <string>

namespace Cosmos {
    namespace Trader {
        struct NetRootConnect{
            std::string accountID{""};
            std::string userid{""};
            std::string password{""};
            std::string frontHost{""};
            int port{0};
        };
        class NetRootTrader : public RootNetTradeSpi{
             Driver::RealtimeDriver * m_driver;
            std::string m_configPath;
            NetRootConnect m_netRootConnect;
            RootNetClientApi m_api;
            OrderCallBackHandler m_orderCallBackHandler;
             Utils::MemoryList< Types::OrderField,  Types::OrderBuffSize> m_receiveOrderList{0};
             Utils::MemoryList< Types::OrderField,  Types::OrderBuffSize>* m_orderList{nullptr};

            BSFlag getOrderSide( Types::OrderSide orderSide) ;

            OffSetFlag getOrderPositionEffect( Types::PositionEffectType pet);

            ExchID getExchangeID( char exchangeID);
        public:
            NetRootTrader( Driver::RealtimeDriver * driver, std::string& configPath):m_driver(driver), m_configPath(configPath){

            }
            int start();
            void sendOrder(  Types::OrderField const & orderField);
            bool cancelOrder( Types::OrderField const & inputOrder, int64_t& epoch_time) ;
            int queryPosition( Types::Instrument_t const&) ;


            void OnQueryAcctInfo(const MsgAccountInfo &accountInfo, const PackHead &msgHead, const RespondInfo &msgRespond){};
            void OnQueryFutAcctInfo(const MsgFutAccountInfo &futAccountInfo, const PackHead &msgHead, const RespondInfo &msgRespond){};
            void OnQueryPosition(const MsgPositionInfo &positionInfo, const PackHead &msgHead, const RespondInfo &msgRespond){};
            void OnTradeEvent(const MsgSubTradeReturn &subTradeReturn, const PackHead &msgHead, const RespondInfo &msgRespond){};


        };
    }
}


#endif //Cosmos_NETROOTTRADE_H
